<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Love-O-Meter™</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap');

  :root{
    --bg-deep:#1a1030;
    --bg-mid:#2b1b3d;
    --rose:#ff6b8b;
    --rose-bright:#ff9bb0;
    --gold:#ffd166;
    --lavender:#e8dfff;
    --cloud:#8a93a6;
    --panel:#241633;
    --panel-edge:rgba(255,214,102,0.18);
  }

  *{box-sizing:border-box; margin:0; padding:0;}

  html,body{
    min-height:100vh;
    background:
      radial-gradient(ellipse at 20% 15%, rgba(255,107,139,0.12), transparent 50%),
      radial-gradient(ellipse at 80% 85%, rgba(255,209,102,0.08), transparent 50%),
      linear-gradient(160deg, var(--bg-deep), var(--bg-mid));
    color:var(--lavender);
    font-family:'Space Mono', monospace;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow-x:hidden;
    padding:24px;
  }

  .stars{
    position:fixed; inset:0; pointer-events:none; z-index:0;
  }
  .star{
    position:absolute; width:2px; height:2px; background:var(--lavender);
    border-radius:50%; opacity:0.5; animation:twinkle 3s ease-in-out infinite;
  }
  @keyframes twinkle{ 50%{ opacity:0.1; } }

  .card{
    position:relative; z-index:1;
    width:100%; max-width:460px;
    background:linear-gradient(180deg, var(--panel), rgba(36,22,51,0.6));
    border:1px solid var(--panel-edge);
    border-radius:28px;
    padding:36px 32px 32px;
    box-shadow:0 30px 80px -20px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.04);
    text-align:center;
  }

  .eyebrow{
    font-family:'Baloo 2', sans-serif; font-weight:700;
    letter-spacing:0.14em; text-transform:uppercase;
    font-size:12px; color:var(--gold); opacity:0.85;
  }

  .title{
    font-family:'Baloo 2', sans-serif; font-weight:800;
    font-size:26px; margin-top:6px; color:var(--lavender);
  }
  .title span{ color:var(--rose-bright); }

  /* the gauge */
  .gauge-wrap{
    position:relative; width:280px; height:280px; margin:28px auto 8px;
  }
  svg.gauge{ width:100%; height:100%; transform:rotate(-90deg); }
  .gauge-track{ fill:none; stroke:rgba(255,255,255,0.06); stroke-width:14; }
  .gauge-fill{
    fill:none; stroke:url(#gaugeGradient); stroke-width:14; stroke-linecap:round;
    transition: stroke-dasharray 0.7s cubic-bezier(.22,1,.36,1);
    filter: drop-shadow(0 0 10px rgba(255,107,139,0.55));
  }

  .number-zone{
    position:absolute; inset:0; display:flex; flex-direction:column;
    align-items:center; justify-content:center;
  }
  .score{
    font-family:'Baloo 2', sans-serif; font-weight:800;
    font-size:76px; line-height:1; color:var(--lavender);
    text-shadow:0 0 30px rgba(255,107,139,0.35);
    transition: transform 0.25s ease;
  }
  .score.bump{ transform:scale(1.12); }
  .score.dip{ transform:scale(0.92) rotate(-1deg); }
  .percent{ font-size:22px; opacity:0.6; margin-left:2px; }
  .status-label{
    margin-top:6px; font-size:12px; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--cloud);
  }

  .controls{
    display:flex; gap:12px; justify-content:center; margin-top:22px;
  }
  button.adjust{
    font-family:'Baloo 2', sans-serif; font-weight:700; font-size:15px;
    border:none; border-radius:14px; padding:12px 20px; cursor:pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  button.adjust:active{ transform:scale(0.94); }
  .btn-up{
    background:linear-gradient(135deg, var(--rose), var(--rose-bright));
    color:#2b1030; box-shadow:0 8px 22px -8px rgba(255,107,139,0.7);
  }
  .btn-down{
    background:rgba(255,255,255,0.06); color:var(--lavender);
    border:1px solid rgba(255,255,255,0.12);
  }
  button.adjust:hover{ filter:brightness(1.08); }

  .custom-row{
    display:flex; gap:8px; margin-top:14px; justify-content:center; align-items:center;
  }
  .custom-row input{
    width:64px; padding:8px 10px; border-radius:10px; border:1px solid rgba(255,255,255,0.12);
    background:rgba(0,0,0,0.2); color:var(--lavender); font-family:'Space Mono', monospace;
    text-align:center; font-size:13px;
  }
  .custom-row button{
    font-family:'Space Mono', monospace; font-size:12px; padding:8px 12px;
    border-radius:10px; border:1px solid rgba(255,255,255,0.12);
    background:rgba(255,255,255,0.04); color:var(--cloud); cursor:pointer;
  }

  .log{
    margin-top:26px; padding-top:16px; border-top:1px dashed rgba(255,255,255,0.1);
    text-align:left; font-size:11px; color:var(--cloud); max-height:78px; overflow-y:auto;
  }
  .log-entry{ padding:2px 0; opacity:0.8; }
  .log-entry.up{ color:var(--rose-bright); }
  .log-entry.down{ color:var(--cloud); }

  /* floating hearts */
  .fx-layer{ position:fixed; inset:0; pointer-events:none; z-index:5; overflow:hidden; }
  .heart{
    position:absolute; font-size:22px; opacity:0; bottom:10%;
    animation: floatUp 1.8s ease-out forwards;
  }
  @keyframes floatUp{
    0%{ opacity:0; transform:translateY(0) scale(0.6) rotate(0deg); }
    15%{ opacity:1; }
    100%{ opacity:0; transform:translateY(-60vh) scale(1.1) rotate(var(--rot)); }
  }

  .cloud{
    position:absolute; top:8%; font-size:30px; opacity:0;
    animation: cloudDrift 1.6s ease-out forwards;
  }
  @keyframes cloudDrift{
    0%{ opacity:0; transform:translateY(-10px); }
    20%{ opacity:0.9; }
    100%{ opacity:0; transform:translateY(30px); }
  }
  .raindrop{
    position:absolute; top:14%; font-size:14px; opacity:0;
    animation: rainFall 1s ease-in forwards;
  }
  @keyframes rainFall{
    0%{ opacity:0; transform:translateY(0); }
    20%{ opacity:0.8; }
    100%{ opacity:0; transform:translateY(120px); }
  }

  .shake{ animation: shakeCard 0.5s ease; }
  @keyframes shakeCard{
    0%,100%{ transform:translateX(0); }
    20%{ transform:translateX(-8px) rotate(-0.5deg); }
    40%{ transform:translateX(7px) rotate(0.5deg); }
    60%{ transform:translateX(-5px); }
    80%{ transform:translateX(4px); }
  }

  .footnote{
    margin-top:18px; font-size:10.5px; color:var(--cloud); opacity:0.6;
  }
</style>
</head>
<body>

<div class="stars" id="stars"></div>
<div class="fx-layer" id="fxLayer"></div>

<div class="card" id="card">
  <div class="eyebrow">Est. relationship analytics</div>
  <div class="title">The <span>Love-O-Meter</span>™</div>

  <div class="gauge-wrap">
    <svg class="gauge" viewBox="0 0 200 200">
      <defs>
        <linearGradient id="gaugeGradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#ff6b8b"/>
          <stop offset="100%" stop-color="#ffd166"/>
        </linearGradient>
      </defs>
      <circle class="gauge-track" cx="100" cy="100" r="86"/>
      <circle class="gauge-fill" id="gaugeFill" cx="100" cy="100" r="86"
              stroke-dasharray="0 540.35" stroke-dashoffset="0"/>
    </svg>
    <div class="number-zone">
      <div class="score" id="score">88<span class="percent">%</span></div>
      <div class="status-label" id="statusLabel">thriving</div>
    </div>
  </div>

  <div class="controls">
    <button class="adjust btn-down" id="btnDown">− 1</button>
    <button class="adjust btn-up" id="btnUp">+ 1</button>
  </div>

  <div class="custom-row">
    <input type="number" id="customAmt" placeholder="5" min="1" max="100">
    <button id="customUp">apply +</button>
    <button id="customDown">apply −</button>
  </div>

  <div class="log" id="log"></div>

  <div class="footnote">purely scientific · results not legally binding</div>
</div>

<script>
  // ---- background stars ----
  const starsEl = document.getElementById('stars');
  for(let i=0;i<40;i++){
    const s = document.createElement('div');
    s.className='star';
    s.style.left = Math.random()*100+'%';
    s.style.top = Math.random()*100+'%';
    s.style.animationDelay = (Math.random()*3)+'s';
    starsEl.appendChild(s);
  }

  // ---- state ----
  let score = 88;
  const CIRC = 2 * Math.PI * 86; // 540.35
  const scoreEl = document.getElementById('score');
  const gaugeFill = document.getElementById('gaugeFill');
  const statusLabel = document.getElementById('statusLabel');
  const card = document.getElementById('card');
  const fxLayer = document.getElementById('fxLayer');
  const logEl = document.getElementById('log');

  function statusFor(v){
    if(v >= 95) return "off the charts";
    if(v >= 80) return "thriving";
    if(v >= 60) return "pretty solid";
    if(v >= 40) return "it's complicated";
    if(v >= 20) return "rocky patch";
    return "send help";
  }

  function render(delta){
    score = Math.max(0, Math.min(100, score));
    scoreEl.innerHTML = score + '<span class="percent">%</span>';
    statusLabel.textContent = statusFor(score);
    const filled = (score/100) * CIRC;
    gaugeFill.setAttribute('stroke-dasharray', filled + ' ' + CIRC);

    scoreEl.classList.remove('bump','dip');
    void scoreEl.offsetWidth; // reflow to restart animation
    if(delta > 0) scoreEl.classList.add('bump');
    if(delta < 0) scoreEl.classList.add('dip');
  }

  function logChange(delta, newVal){
    const entry = document.createElement('div');
    entry.className = 'log-entry ' + (delta > 0 ? 'up' : 'down');
    const sign = delta > 0 ? '+' : '';
    const now = new Date();
    const time = now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
    entry.textContent = `${time}  ${sign}${delta}  →  ${newVal}%`;
    logEl.prepend(entry);
  }

  function spawnHearts(count){
    const hearts = ['💕','💖','✨','💗'];
    for(let i=0;i<count;i++){
      const h = document.createElement('div');
      h.className = 'heart';
      h.textContent = hearts[Math.floor(Math.random()*hearts.length)];
      h.style.left = (40 + Math.random()*20) + '%';
      h.style.setProperty('--rot', (Math.random()*40-20)+'deg');
      h.style.animationDelay = (Math.random()*0.3)+'s';
      fxLayer.appendChild(h);
      setTimeout(()=>h.remove(), 2200);
    }
  }

  function spawnRainCloud(){
    const cloud = document.createElement('div');
    cloud.className = 'cloud';
    cloud.textContent = '🌧️';
    cloud.style.left = '46%';
    fxLayer.appendChild(cloud);
    setTimeout(()=>cloud.remove(), 1800);

    for(let i=0;i<5;i++){
      const drop = document.createElement('div');
      drop.className = 'raindrop';
      drop.textContent = '💧';
      drop.style.left = (40 + Math.random()*20) + '%';
      drop.style.animationDelay = (0.2 + Math.random()*0.4)+'s';
      fxLayer.appendChild(drop);
      setTimeout(()=>drop.remove(), 1400);
    }

    card.classList.remove('shake');
    void card.offsetWidth;
    card.classList.add('shake');
  }

  function adjust(delta){
    const newVal = Math.max(0, Math.min(100, score + delta));
    const actualDelta = newVal - score;
    score = newVal;
    render(actualDelta);
    if(actualDelta !== 0) logChange(actualDelta, score);
    if(actualDelta > 0) spawnHearts(Math.min(10, 4 + actualDelta));
    if(actualDelta < 0) spawnRainCloud();
  }

  document.getElementById('btnUp').addEventListener('click', ()=>adjust(1));
  document.getElementById('btnDown').addEventListener('click', ()=>adjust(-1));
  document.getElementById('customUp').addEventListener('click', ()=>{
    const amt = parseInt(document.getElementById('customAmt').value) || 0;
    if(amt>0) adjust(amt);
  });
  document.getElementById('customDown').addEventListener('click', ()=>{
    const amt = parseInt(document.getElementById('customAmt').value) || 0;
    if(amt>0) adjust(-amt);
  });

  render(0);
</script>

</body>
</html>

